{
    "name": "ngos/admin-core",
    "description": "Reusable admin CRUD core (config-driven controllers/services, Route::crud macro, resource generator) for Laravel + Bootstrap 5, with a custom branded admin theme.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "admin",
        "crud",
        "generator",
        "theme",
        "bootstrap",
        "datatables",
        "scaffold"
    ],
    "homepage": "https://github.com/ngouyoung/admin-core",
    "authors": [
        {
            "name": "ngos",
            "email": "ngouyuong@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/ngouyoung/admin-core/issues",
        "source": "https://github.com/ngouyoung/admin-core"
    },
    "require": {
        "php": "^8.3",
        "composer-runtime-api": "^2.2",
        "guzzlehttp/guzzle": "^7.8",
        "illuminate/auth": "^13.0",
        "illuminate/cache": "^13.0",
        "illuminate/console": "^13.0",
        "illuminate/contracts": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/filesystem": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/notifications": "^13.0",
        "illuminate/process": "^13.0",
        "illuminate/routing": "^13.0",
        "illuminate/support": "^13.0",
        "illuminate/translation": "^13.0",
        "illuminate/validation": "^13.0",
        "illuminate/view": "^13.0",
        "spatie/laravel-permission": "^8.0",
        "yajra/laravel-datatables-oracle": "^13.0",
        "intervention/image": "^3.0",
        "pragmarx/google2fa": "^8.0",
        "bacon/bacon-qr-code": "^3.0",
        "ext-dom": "*"
    },
    "suggest": {
        "laravel/passport": "Required for `admin-core:install --api-auth` — OAuth2 (password grant) API auth for a decoupled front-end"
    },
    "autoload": {
        "psr-4": {
            "Ngos\\AdminCore\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Ngos\\AdminCore\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "analyse": "phpstan analyse --memory-limit=512M"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ngos\\AdminCore\\AdminCoreServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require-dev": {
        "orchestra/testbench": "*",
        "pestphp/pest": "*",
        "pestphp/pest-plugin-laravel": "*",
        "larastan/larastan": "^3.0"
    }
}
