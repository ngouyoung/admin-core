<!DOCTYPE html>
<html lang="{{ str_replace('_', '-', app()->getLocale()) }}" data-bs-theme="light">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="csrf-token" content="{{ csrf_token() }}">
    <title>{{ setting('app_name', config('app.name')) }} | @yield('title', 'Dashboard')</title>

    {{-- Apply saved Customize settings before paint (no flash). See resources/js/customize.js --}}
    <script>
        (function () {
            try {
                var c = JSON.parse(localStorage.getItem('ac-customize') || '{}');
                var el = document.documentElement, t = c.theme || 'light';
                if (t === 'system') t = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
                el.setAttribute('data-bs-theme', t);
                el.setAttribute('data-ac-accent', c.accent || 'neutral');
                el.setAttribute('data-ac-density', c.density || 'comfortable');
                el.setAttribute('data-ac-layout', c.layout || 'sidebar');
                el.setAttribute('data-ac-container', c.container || 'fluid');
                el.setAttribute('dir', c.direction || 'ltr');
            } catch (e) {}
        })();
    </script>

    {{-- Load the built theme when it's available (Vite dev server running, or `npm run build` done);
         otherwise render without it instead of throwing ViteManifestNotFoundException on a fresh
         install. Run `npm install && npm run build` for the full admin-core theme. --}}
    @if (file_exists(public_path('hot')) || file_exists(public_path('build/manifest.json')))
        @vite(['resources/js/app.js'])
    @endif
    @stack('style')
</head>
<body>
<div class="ac-shell">
    @include('backend.partials.sidebar')
    @include('backend.partials.nav')

    <main class="ac-main">
        @hasSection('breadcrumb')
            <div class="mb-3">@yield('breadcrumb')</div>
        @endif
        @foreach (['success' => 'success', 'error' => 'danger', 'warning' => 'warning', 'info' => 'info'] as $flash => $variant)
            @if (session($flash))
                <div class="alert alert-{{ $variant }}">{{ session($flash) }}</div>
            @endif
        @endforeach
        @yield('contents')
    </main>

    @include('backend.partials.footer')
</div>
<div class="ac-overlay" data-ac-toggle="sidebar"></div>
@include('backend.partials.customize')
@stack('scripts')
</body>
</html>
