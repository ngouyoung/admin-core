<!DOCTYPE html>
<html lang="{{ str_replace('_', '-', app()->getLocale()) }}" data-bs-theme="light">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="csrf-token" content="{{ csrf_token() }}">
    @auth
        @if (config('admin-core.notifications.realtime'))
            {{-- Laravel broadcasts notifications on a private channel named after the notifiable
                 (FQCN with \ → . , then the key); the realtime bell (resources/js/realtime.js) listens here. --}}
            <meta name="ac-user-channel" content="{{ str_replace('\\', '.', get_class(auth()->user())) . '.' . auth()->id() }}">
        @endif
    @endauth
    <title>{{ setting('app_name', config('app.name')) }} | @yield('title', 'Dashboard')</title>

    {{-- Apply saved Customize settings before paint (no flash). See resources/js/customize.js --}}
    <script>
        (function () {
            try {
                var c = JSON.parse(localStorage.getItem('ac-customize') || '{}');
                var el = document.documentElement, t = c.theme || 'light';
                if (t === 'system') t = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
                el.setAttribute('data-bs-theme', t);
                el.setAttribute('data-ac-accent', c.accent || 'neutral');
                el.setAttribute('data-ac-density', c.density || 'comfortable');
                el.setAttribute('data-ac-layout', c.layout || 'sidebar');
                el.setAttribute('data-ac-container', c.container || 'fluid');
                el.setAttribute('dir', c.direction || 'ltr');
            } catch (e) {}
        })();
    </script>

    {{-- Load the built theme when it's available (Vite dev server running, or `npm run build` done);
         otherwise render without it instead of throwing ViteManifestNotFoundException on a fresh
         install. Run `npm install && npm run build` for the full admin-core theme. --}}
    @if (file_exists(public_path('hot')) || file_exists(public_path('build/manifest.json')))
        @vite(['resources/js/app.js'])
    @endif
    @stack('style')
</head>
<body>
<div class="ac-shell">
    @include('backend.partials.sidebar')
    @include('backend.partials.nav')

    <main class="ac-main">
        @hasSection('breadcrumb')
            <div class="mb-3">@yield('breadcrumb')</div>
        @endif
        {{-- Flash messages pop as toastr toasts (same feedback as AJAX actions, not a static alert box). --}}
        @foreach (['success', 'error', 'warning', 'info'] as $flash)
            @if (session($flash))
                @push('scripts')
                    <script>window.toastr && window.toastr.{{ $flash }}(@json(session($flash)));</script>
                @endpush
            @endif
        @endforeach
        @yield('contents')
    </main>

    @include('backend.partials.footer')
</div>
<div class="ac-overlay" data-ac-toggle="sidebar"></div>
@include('backend.partials.customize')
@stack('scripts')
<script>
    // Reusable confirm — any <form data-confirm="…"> or <a data-confirm="…"> asks via SweetAlert
    // (the already-loaded library) before proceeding. Keeps every confirmation consistent; no native confirm().
    (function () {
        function ask(message, onYes) {
            window.Swal.fire({
                title: message, icon: 'warning', showCancelButton: true,
                confirmButtonText: '{{ __('admin-core::admin-core.confirm.yes_delete') }}',
                cancelButtonText: '{{ __('admin-core::admin-core.confirm.no_keep') }}',
            }).then(function (r) { if (r.value) onYes(); });
        }
        document.addEventListener('submit', function (e) {
            var f = e.target.closest('form[data-confirm]');
            if (f) { e.preventDefault(); ask(f.dataset.confirm, function () { f.submit(); }); }
        });
        document.addEventListener('click', function (e) {
            var a = e.target.closest('a[data-confirm]');
            if (a) { e.preventDefault(); ask(a.dataset.confirm, function () { window.location = a.href; }); }
        });
    })();
</script>
</body>
</html>
