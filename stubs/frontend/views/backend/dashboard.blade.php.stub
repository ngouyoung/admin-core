            ['label' => 'Group Permissions', 'count' => \App\Models\GroupPermission::count(), 'icon' => 'bi-collection', 'bg' => 'info', 'route' => 'admin.assessments.group_permissions.index', 'color' => '#0dcaf0'],
        ];
