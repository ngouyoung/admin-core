@push('scripts')
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const el = document.querySelector('#overview-chart');
            if (el && window.ApexCharts) {
                new window.ApexCharts(el, {
                    chart: { type: 'donut', height: 300, fontFamily: 'inherit' },
                    series: [{{ collect($stats)->pluck('count')->implode(', ') }}],
                    labels: @json(collect($stats)->pluck('label')),
                    colors: @json(collect($stats)->pluck('color')),
                    legend: { position: 'bottom' },
                    dataLabels: { enabled: true },
                }).render();
            }
        });
    </script>
@endpush
