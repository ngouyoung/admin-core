<?php

use App\Http\Controllers\Backend\DummyClassController;
use Illuminate\Support\Facades\Route;

Route::group(['prefix' => 'dummyModels', 'as' => 'dummyModels.'], function () {
    Route::crud('dummy-model', DummyClassController::class);

    Route::controller(DummyClassController::class)->group(function () {
        Route::get('show/{id}', 'show')->name('show')
            ->middleware(config('admin-core.permission.enabled') ? 'permission:list-dummy-model' : []);
        Route::get('export', 'export')->name('export')
            ->middleware(config('admin-core.permission.enabled') ? 'permission:list-dummy-model' : []);
        Route::post('bulkDelete', 'bulkDelete')->name('bulkDelete')
            ->middleware(config('admin-core.permission.enabled') ? 'permission:delete-dummy-model' : []);
    });
__AC_SOFT_ROUTES__
__AC_SORT_ROUTES__
});
