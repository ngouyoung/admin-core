                order: [[0, 'desc']],
                columns: [
                    {data: 'when', name: 'created_at'},
                    {data: 'type', name: 'type'},
                    {data: 'message', name: 'message'},
                    {data: 'url', name: 'url'},
                    {data: 'actions', orderable: false, searchable: false},
                ],
            });
