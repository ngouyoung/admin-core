        {{-- ──────────────────────────── Field types ──────────────────────────── --}}
        <x-admin-core::tab-pane id="fields">
            <x-admin-core::card>
                <x-slot:header>The <code>--fields</code> DSL</x-slot>
                <p>Comma-separated <code>name:type</code> tokens. Example:
                    <code>"title:string^, body:text?, status:enum:draft|published, category_id:foreign"</code></p>
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead><tr><th>Type</th><th>Renders</th></tr></thead>
                        <tbody>
                            <tr><td><code>string</code> / <code>text</code></td><td>Input / textarea</td></tr>
                            <tr><td><code>integer</code> / <code>decimal</code></td><td>Number input</td></tr>
                            <tr><td><code>boolean</code></td><td>Checkbox (Yes/No badge in the list)</td></tr>
                            <tr><td><code>date</code> / <code>datetime</code> / <code>time</code></td><td>Date picker</td></tr>
                            <tr><td><code>email</code> / <code>url</code> / <code>slug</code></td><td>Validated input</td></tr>
                            <tr><td><code>enum:a|b|c</code></td><td>Select + generated backed enum + status pill</td></tr>
                            <tr><td><code>json</code></td><td>JSON textarea (cast to array)</td></tr>
                            <tr><td><code>image</code> / <code>file</code></td><td>Upload (stored on the public disk)</td></tr>
                            <tr><td><code>password</code></td><td>Hashed, hidden from the list</td></tr>
                            <tr><td><code>foreign</code> (<code>x_id:foreign</code>)</td><td>belongsTo + select2 dropdown</td></tr>
                            <tr><td><code>belongsToMany</code></td><td>Pivot + multi-select</td></tr>
                        </tbody>
                    </table>
                </div>
                <p class="mb-0">Modifiers (suffix): <code>?</code> nullable &middot; <code>^</code> unique &middot;
                    <code>#</code> indexed &middot; <code>~</code> write-once &middot; <code>{{ '@' }}</code> system (set in code).
                    Run <code>php artisan admin-core:make --list-fields</code> for the full catalog.</p>
            </x-admin-core::card>
        </x-admin-core::tab-pane>

