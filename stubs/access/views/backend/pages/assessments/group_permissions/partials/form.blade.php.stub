<x-admin-core::input name="name" label="Name" :value="old('name', $object->name ?? null)" placeholder="Name" />
<x-admin-core::select name="parent_id" label="Parent" :options="$groups->pluck('name', 'id')"
                     :value="old('parent_id', $object->parent_id ?? null)" placeholder="— none (top level) —" />
