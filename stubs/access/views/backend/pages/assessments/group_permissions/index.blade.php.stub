@push('scripts')
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const refreshTable = function () {
                $.get("{{ route('admin.assessments.group_permissions.table') }}", function (html) {
                    $('#group_table_body').html(html);
                    $('#group_table_body [data-bs-toggle="tooltip"]').each(function () {
                        window.bootstrap.Tooltip.getOrCreateInstance(this);
                    });
                });
            };

            const nestable = $('#nestable');
            nestable.nestable({group: 1, maxDepth: 10}).on('change', function () {
                $.ajax({
                    url: "{{ route('admin.assessments.group_permissions.sort') }}",
                    type: "post",
                    data: {data: nestable.nestable('serialize')},
                    success: function (data) {
                        if (data.status === "OK") {
                            refreshTable();
                            window.toastr.success('{{ __('admin-core::admin-core.toast.order_updated') }}');
                        } else window.toastr.error('{{ __('admin-core::admin-core.toast.error') }}');
                    },
                    error: function (xhr, status, error) { window.toastr.error(error); }
                });
            });

            $(document).on('click', '#delete', function (e) {
                e.preventDefault();
                const url = $(this).attr('data-remote');
                Swal.fire({
                    title: '{{ __('admin-core::admin-core.confirm.title') }}', text: '{{ __('admin-core::admin-core.confirm.recover_one') }}',
                    icon: 'warning', showCancelButton: true,
                    confirmButtonText: '{{ __('admin-core::admin-core.confirm.yes_delete') }}', cancelButtonText: '{{ __('admin-core::admin-core.confirm.no_keep') }}'
                }).then((result) => {
                    if (result.value) {
                        $.ajax({type: "DELETE", url: url, success: function () {
                            location.reload();
                        }});
                    }
                });
            });
        });
    </script>
@endpush
