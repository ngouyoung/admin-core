                </select>
            </div>

            <div class="mb-3 d-none" data-link="url">
                <label class="form-label" for="menu-url">URL</label>
                <input type="text" name="url" id="menu-url" class="form-control" placeholder="https://… or /admin/x">
            </div>

            <div class="mb-3">
                <label class="form-label" for="menu-match">Active highlight pattern <span class="text-muted small">(optional)</span></label>
                <input type="text" name="match" id="menu-match" class="form-control" placeholder="admin/products*">
                <div class="form-text">A <code>request()->is()</code> pattern that marks the item “active”.</div>
            </div>

            <div class="mb-3">
                <label class="form-label" for="menu-permission">Permission <span class="text-muted small">(optional)</span></label>
                <select name="permission" id="menu-permission" class="form-select">
                    <option value="">— visible to everyone —</option>
                    @foreach ($permissions as $p)
                        <option value="{{ $p }}">{{ $p }}</option>
                    @endforeach
                </select>
                <div class="form-text">Hidden unless the signed-in admin has this permission.</div>
            </div>

            <div class="form-check form-switch mb-3">
                <input type="checkbox" class="form-check-input" name="target" id="menu-target" value="_blank">
                <label class="form-check-label" for="menu-target">Open in a new tab</label>
            </div>

            <div class="form-check form-switch mb-4">
                <input type="checkbox" class="form-check-input" name="is_active" id="menu-active" value="1" checked>
                <label class="form-check-label" for="menu-active">Active (shown in the sidebar)</label>
            </div>

            <button type="submit" class="btn btn-primary w-100"><i class="bi bi-check-lg"></i> Save</button>
        </form>
    </div>
