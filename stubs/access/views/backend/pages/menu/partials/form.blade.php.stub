{{-- Add / edit offcanvas. The same form is reused: the edit buttons (see scripts) swap
     the action + _method and pre-fill the fields from the row's data-* attributes. --}}
<div class="offcanvas offcanvas-end" tabindex="-1" id="menu-form" aria-labelledby="menu-form-title">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="menu-form-title">Add menu item</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body">
        <form id="menu-form-el" method="post" action="{{ route('admin.menu.store') }}">
            @csrf
            <input type="hidden" name="_method" id="menu-method" value="POST">
            <input type="hidden" name="parent_id" id="menu-parent" value="">

            <div class="mb-3">
                <label class="form-label" for="menu-label">Label</label>
