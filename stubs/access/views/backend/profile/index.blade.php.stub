@push('scripts')
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const modalEl = document.getElementById('cropModal');
            const modal = window.bootstrap.Modal.getOrCreateInstance(modalEl);
            let croppie = null;
            let rawImg = null;

            document.getElementById('change-avatar-btn').addEventListener('click', function () {
                document.getElementById('avatar-input').click();
            });

            document.getElementById('avatar-input').addEventListener('change', function (e) {
                const file = e.target.files[0];
                if (!file) return;
                const reader = new FileReader();
                reader.onload = function (ev) { rawImg = ev.target.result; modal.show(); };
                reader.readAsDataURL(file);
            });

            modalEl.addEventListener('shown.bs.modal', function () {
                if (!croppie) {
                    croppie = $('#croppie-area').croppie({
                        viewport: { width: 200, height: 200, type: 'circle' },
                        boundary: { width: 280, height: 280 },
                        enableExif: true,
                    });
                }
                $('#croppie-area').croppie('bind', { url: rawImg });
            });

            document.getElementById('crop-save').addEventListener('click', function () {
                $('#croppie-area').croppie('result', {
                    type: 'base64', format: 'jpeg', size: { width: 200, height: 200 },
                }).then(function (base64) {
                    document.getElementById('avatar-data').value = base64;
                    document.getElementById('avatar-form').submit();
                });
            });
        });
    </script>
@endpush
