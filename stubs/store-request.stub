<?php

namespace App\Http\Requests\DummyClass;

use Illuminate\Foundation\Http\FormRequest;

class StoreDummyClassRequest extends FormRequest
{
    public function authorize(): bool
    {
        return $this->user()->can('create-dummy-model');
    }

    public function rules(): array
    {
        return [
            'name' => ['required', 'string', 'max:255'],
        ];
    }
}
